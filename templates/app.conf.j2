# {{ app_name }} configuration
# Environment: {{ app_env }}
# Generated by Ansible — do not edit manually
 
[application]
name = {{ app_name }}
port = {{ app_port }}
app_env = {{ app_env }}
log_directory = /opt/{{ app_name }}/logs
 
[server]
workers = {{ nginx_worker_processes }}
server_name = {{ nginx_server_name }}
max_connections = {% if app_env == 'production' %}1024{% else %}256{% endif %}
 
[logging]
level = {% if app_env == 'production' %}WARNING{% else %}DEBUG{% endif %}
 
log_file = /opt/{{ app_name }}/logs/{{ app_name }}.log